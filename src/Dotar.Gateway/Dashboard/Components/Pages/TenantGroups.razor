@page "/grupos"
@page "/grupos/create"
@page "/grupos/{Id:int}/edit"
@using Dotar.Gateway.Domain.Entities
@using Dotar.Gateway.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Navigation

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Folder" Class="mr-2" />
    @(_isEditing ? "Editar Grupo" : _isCreating ? "Nuevo Grupo" : "Grupos de Tenants")
</MudText>

@if (_isCreating || _isEditing)
{
    <MudPaper Class="pa-6" MaxWidth="600px" Elevation="2">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_form.Name" Label="Nombre del Grupo"
                          Placeholder="Cliente 1" Variant="Variant.Outlined" />
            <MudSelect T="int" @bind-Value="_form.RetryPolicyId" Label="Política de Reintento"
                       HelperText="Se hereda a los tenants sin política propia"
                       Variant="Variant.Outlined">
                <MudSelectItem T="int" Value="0">— Usar política por defecto del sistema —</MudSelectItem>
                @foreach (var p in _policies)
                {
                    <MudSelectItem T="int" Value="@p.Id">@p.Name (@(p.Steps.Count) pasos)</MudSelectItem>
                }
            </MudSelect>

            <MudStack Row="true" Spacing="2" Class="mt-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save" OnClick="SaveGroup">
                    Guardar
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/grupos">Cancelar</MudButton>
            </MudStack>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-2">@_errorMessage</MudAlert>
            }
        </MudStack>
    </MudPaper>
}
else
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" Href="/grupos/create" Class="mb-4">
        Nuevo Grupo
    </MudButton>

    @if (_groups.Any())
    {
        <MudSimpleTable Hover="true" Dense="true" Elevation="2">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Política</th>
                    <th>Tenants</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in _groups)
                {
                    <tr>
                        <td><strong>@g.Name</strong></td>
                        <td>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                @(g.RetryPolicy?.Name ?? "Default del sistema")
                            </MudChip>
                        </td>
                        <td>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">
                                @g.Tenants.Count tenants
                            </MudChip>
                        </td>
                        <td>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Href="@($"/grupos/{g.Id}/edit")" />
                            @if (g.Tenants.Count == 0)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="() => DeleteGroup(g.Id)" />
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No hay grupos configurados. ¡Crea el primero para agrupar tus tenants!
        </MudAlert>
    }
}

@code {
    [Parameter] public int? Id { get; set; }

    private List<TenantGroup> _groups = [];
    private List<RetryPolicy> _policies = [];
    private GroupFormModel _form = new();
    private string? _errorMessage;

    private bool _isCreating => Navigation.Uri.EndsWith("/create", StringComparison.OrdinalIgnoreCase);
    private bool _isEditing => Navigation.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        await HandleRouteAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(async () => { await HandleRouteAsync(); StateHasChanged(); });
    }

    private async Task HandleRouteAsync()
    {
        _errorMessage = null;
        if (_isEditing)
        {
            var editId = ExtractIdFromUri();
            if (editId.HasValue) { Id = editId; await LoadGroupForEdit(editId.Value); }
        }
        else if (_isCreating) { _form = new GroupFormModel(); }
        await LoadData();
    }

    private int? ExtractIdFromUri()
    {
        var uri = Navigation.Uri;
        var match = System.Text.RegularExpressions.Regex.Match(uri, @"/grupos/(\d+)/edit",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return match.Success && int.TryParse(match.Groups[1].Value, out var id) ? id : null;
    }

    private async Task LoadGroupForEdit(int groupId)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        var group = await db.TenantGroups.FindAsync(groupId);
        if (group is not null)
        {
            _form = new GroupFormModel { Name = group.Name, RetryPolicyId = group.RetryPolicyId ?? 0 };
        }
    }

    private async Task LoadData()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        _groups = await db.TenantGroups
            .Include(g => g.RetryPolicy).Include(g => g.Tenants)
            .OrderBy(g => g.Name).ToListAsync();
        _policies = await db.RetryPolicies.Include(p => p.Steps).OrderBy(p => p.Name).ToListAsync();
    }

    private async Task SaveGroup()
    {
        _errorMessage = null;
        if (string.IsNullOrWhiteSpace(_form.Name)) { _errorMessage = "El nombre es obligatorio."; return; }

        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();

        if (_isEditing && Id.HasValue)
        {
            var group = await db.TenantGroups.FindAsync(Id.Value);
            if (group is null) return;
            group.Name = _form.Name;
            group.RetryPolicyId = _form.RetryPolicyId == 0 ? null : _form.RetryPolicyId;
        }
        else
        {
            db.TenantGroups.Add(new TenantGroup
            {
                Name = _form.Name,
                RetryPolicyId = _form.RetryPolicyId == 0 ? null : _form.RetryPolicyId,
                CreatedAt = DateTime.UtcNow
            });
        }
        await db.SaveChangesAsync();
        Navigation.NavigateTo("/grupos");
    }

    private async Task DeleteGroup(int id)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        var group = await db.TenantGroups.FindAsync(id);
        if (group is not null) { db.TenantGroups.Remove(group); await db.SaveChangesAsync(); }
        await LoadData();
    }

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;

    private class GroupFormModel
    {
        public string Name { get; set; } = string.Empty;
        public int RetryPolicyId { get; set; }
    }
}

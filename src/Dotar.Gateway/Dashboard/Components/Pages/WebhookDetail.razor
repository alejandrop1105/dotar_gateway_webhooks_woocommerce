@page "/monitor/{LogId:long}"
@using Dotar.Gateway.Domain.Entities
@using Dotar.Gateway.Infrastructure.Data
@using Dotar.Gateway.Infrastructure.Services
@using Dotar.Gateway.Workers
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Navigation
@inject WebhookDispatcherWorker Worker
@inject MonitorNotificationService MonitorNotify
@inject IJSRuntime JS
@implements IDisposable

<MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/monitor"
           StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-4">
    Volver al Monitor
</MudButton>

@if (_log is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Webhook no encontrado.
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Article" Class="mr-2" /> Detalle del Webhook #@_log.Id
    </MudText>

    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                <MudText Typo="Typo.h5">@_log.Tenant.Name</MudText>
                <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">Tenant</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                <MudChip T="string" Size="Size.Medium"
                         Color="@(_log.Status == DeliveryStatus.Success || _log.Status == DeliveryStatus.ManualRetry ? Color.Success : _log.Status == DeliveryStatus.Scheduled ? Color.Primary : Color.Error)">
                    @GetStatusLabel(_log.Status)
                </MudChip>
                <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">Estado Actual</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                <MudText Typo="Typo.h3" Color="Color.Primary">@_log.AttemptNumber</MudText>
                <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">Intentos Totales</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                <MudText Typo="Typo.h6">@_log.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm:ss")</MudText>
                <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">Recibido</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudStack Spacing="2">
            @if (!string.IsNullOrEmpty(_log.SourceUrl))
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">URL Origen:</MudText>
                    <MudText Typo="Typo.body2"><code>@_log.SourceUrl</code></MudText>
                </MudStack>
            }
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.body2" Color="Color.Secondary">URL Destino:</MudText>
                <MudText Typo="Typo.body2"><code>@(_log.TargetUrl ?? _log.Tenant.TargetUrl)</code></MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Event ID:</MudText>
                <MudText Typo="Typo.body2"><code>@_log.WebhookEventId</code></MudText>
            </MudStack>
            @if (_log.NextRetryAt.HasValue && _log.Status == DeliveryStatus.Scheduled)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Próximo reintento:</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Warning">
                        @_log.NextRetryAt.Value.ToLocalTime().ToString("dd/MM HH:mm:ss")
                        <small>(en @FormatTimeUntil(_log.NextRetryAt.Value))</small>
                    </MudText>
                </MudStack>
            }
        </MudStack>
    </MudPaper>

    @if (_log.Status == DeliveryStatus.Failed || _log.Status == DeliveryStatus.Scheduled)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.Replay" OnClick="RetryNow"
                   Disabled="_isRetrying" Class="mb-4">
            @(_isRetrying ? "Enviando..." : "Reenviar Ahora")
        </MudButton>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <MudAlert Severity="@(_messageClass == "alert-success" ? Severity.Success : Severity.Error)"
                  Class="mb-4">
            @_message
        </MudAlert>
    }

    <MudText Typo="Typo.h5" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Timeline" Class="mr-2" /> Historial de Intentos
    </MudText>

    <MudTimeline TimelinePosition="TimelinePosition.Start" Class="mb-4">
        @foreach (var attempt in _attempts)
        {
            var isSuccess = attempt.HttpStatusCode.HasValue && attempt.HttpStatusCode >= 200 && attempt.HttpStatusCode < 300;
            <MudTimelineItem Color="@(isSuccess ? Color.Success : Color.Error)" Size="Size.Medium">
                <MudPaper Class="pa-3" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                        <MudText Typo="Typo.subtitle2">Intento #@attempt.AttemptNumber</MudText>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(isSuccess ? Color.Success : Color.Error)">
                            @(attempt.IsManual ? (isSuccess ? "Manual OK" : "Manual") : (isSuccess ? "Auto OK" : "Auto"))
                        </MudChip>
                        <MudSpacer />
                        <MudText Typo="Typo.caption">@attempt.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm:ss")</MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="4">
                        <MudText Typo="Typo.body2">HTTP: <strong>@(attempt.HttpStatusCode ?? 0)</strong></MudText>
                        <MudText Typo="Typo.body2">Duración: <strong>@attempt.DurationMs ms</strong></MudText>
                    </MudStack>
                    @if (!string.IsNullOrEmpty(attempt.ErrorMessage))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Error" Class="mt-1">
                            ❌ @attempt.ErrorMessage
                        </MudText>
                    }
                </MudPaper>
            </MudTimelineItem>
        }
    </MudTimeline>

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.DataObject" Class="mr-2" /> Payload
        </MudText>
        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyPayload">
            @(_copied ? "✅ Copiado!" : "Copiar")
        </MudButton>
    </MudStack>
    <MudPaper Class="pa-4" Elevation="2" Style="overflow-x: auto;">
        <pre style="margin:0; font-size:0.85rem; color: var(--mud-palette-text-primary);"><code>@FormatJson(_log.Payload)</code></pre>
    </MudPaper>
}

@code {
    [Parameter] public long LogId { get; set; }
    private DeliveryLog? _log;
    private List<DeliveryAttempt> _attempts = [];
    private bool _isRetrying;
    private bool _copied;
    private string? _message;
    private string _messageClass = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        MonitorNotify.OnDeliveryChanged += OnChanged;
        await LoadData();
    }

    private async Task OnChanged()
    {
        await InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    private async Task LoadData()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        _log = await db.DeliveryLogs
            .Include(l => l.Tenant)
            .Include(l => l.Attempts.OrderBy(a => a.AttemptNumber))
            .FirstOrDefaultAsync(l => l.Id == LogId);
        _attempts = _log?.Attempts ?? [];
    }

    private async Task RetryNow()
    {
        _isRetrying = true; _message = null;
        var result = await Worker.RetryManualAsync(LogId);
        _message = result.IsSuccess
            ? $"✅ Reenvío exitoso (HTTP {result.StatusCode})"
            : $"❌ Falló: {result.ErrorMessage}";
        _messageClass = result.IsSuccess ? "alert-success" : "alert-danger";
        _isRetrying = false;
        await LoadData();
    }

    private async Task CopyPayload()
    {
        if (_log?.Payload is null) return;
        var json = FormatJson(_log.Payload);
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", json);
        _copied = true; StateHasChanged();
        await Task.Delay(2000);
        _copied = false; StateHasChanged();
    }

    private string GetStatusLabel(DeliveryStatus s) => s switch
    {
        DeliveryStatus.Success => "✅ Éxito",
        DeliveryStatus.ManualRetry => "🔄 Manual OK",
        DeliveryStatus.Scheduled => "⏳ Programado",
        _ => "❌ Fallido"
    };

    private static string FormatJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "(vacío)";
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(json);
            return System.Text.Json.JsonSerializer.Serialize(doc, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch { return json; }
    }

    private static string FormatTimeUntil(DateTime futureUtc)
    {
        var diff = futureUtc - DateTime.UtcNow;
        if (diff.TotalSeconds <= 0) return "ahora";
        if (diff.TotalDays >= 1) return $"{(int)diff.TotalDays}d {diff.Hours}h";
        if (diff.TotalHours >= 1) return $"{(int)diff.TotalHours}h {diff.Minutes}min";
        if (diff.TotalMinutes >= 1) return $"{(int)diff.TotalMinutes}min {diff.Seconds}s";
        return $"{(int)diff.TotalSeconds}s";
    }

    public void Dispose() => MonitorNotify.OnDeliveryChanged -= OnChanged;
}

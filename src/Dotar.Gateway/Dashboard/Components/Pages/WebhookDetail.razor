@page "/monitor/{LogId:long}"
@using Dotar.Gateway.Domain.Entities
@using Dotar.Gateway.Infrastructure.Data
@using Dotar.Gateway.Infrastructure.Services
@using Dotar.Gateway.Workers
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Navigation
@inject WebhookDispatcherWorker Worker
@inject MonitorNotificationService MonitorNotify
@inject IJSRuntime JS
@implements IDisposable

<div style="margin-bottom: 1rem;">
    <a href="/monitor" class="btn btn-secondary btn-sm">← Volver al Monitor</a>
</div>

@if (_log is null)
{
    <p class="empty-state">Webhook no encontrado.</p>
}
else
{
    <h1>📋 Detalle del Webhook #@_log.Id</h1>

    <!-- Info del Webhook -->
    <div class="stats-grid" style="margin-bottom: 1.5rem;">
        <div class="stat-card">
            <div class="stat-value" style="font-size: 1.5rem;">@_log.Tenant.Name</div>
            <div class="stat-label">Tenant</div>
        </div>
        <div
            class="stat-card @(_log.Status == DeliveryStatus.Success || _log.Status == DeliveryStatus.ManualRetry ? "success" : _log.Status == DeliveryStatus.Scheduled ? "accent" : "danger")">
            <div class="stat-value" style="font-size: 1.5rem;">@GetStatusLabel(_log.Status)</div>
            <div class="stat-label">Estado Actual</div>
        </div>
        <div class="stat-card accent">
            <div class="stat-value">@_log.AttemptNumber</div>
            <div class="stat-label">Intentos Totales</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="font-size: 1.2rem;">@_log.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm:ss")
            </div>
            <div class="stat-label">Recibido</div>
        </div>
    </div>

    <!-- URL y Acciones -->
    <div class="detail-section">
        <div class="detail-row">
            <span class="detail-label">URL Destino:</span>
            <code class="detail-value">@(_log.TargetUrl ?? _log.Tenant.TargetUrl)</code>
        </div>
        <div class="detail-row">
            <span class="detail-label">Event ID:</span>
            <code class="detail-value">@_log.WebhookEventId</code>
        </div>
        @if (_log.NextRetryAt.HasValue && _log.Status == DeliveryStatus.Scheduled)
        {
            <div class="detail-row">
                <span class="detail-label">Próximo reintento:</span>
                <span class="detail-value" style="color: var(--warning);">
                    @_log.NextRetryAt.Value.ToLocalTime().ToString("dd/MM HH:mm:ss")
                    <small>(en @FormatTimeUntil(_log.NextRetryAt.Value))</small>
                </span>
            </div>
        }
    </div>

    <div class="form-actions" style="margin-bottom: 1.5rem;">
        @if (_log.Status == DeliveryStatus.Failed || _log.Status == DeliveryStatus.Scheduled)
        {
            <button class="btn btn-success" @onclick="RetryNow" disabled="@_isRetrying">
                @if (_isRetrying)
                {
                    <span>⏳ Enviando...</span>
                }
                else
                {
                    <span>🔄 Reenviar Ahora</span>
                }
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @_messageClass" style="margin-bottom: 1rem;">@_message</div>
    }

    <!-- Timeline de Intentos -->
    <h2>📊 Historial de Intentos</h2>
    <div class="attempts-timeline">
        @foreach (var attempt in _attempts)
        {
            var isSuccess = attempt.HttpStatusCode.HasValue && attempt.HttpStatusCode >= 200 && attempt.HttpStatusCode < 300;
            <div class="attempt-card @(isSuccess ? "attempt-success" : "attempt-failed")">
                <div class="attempt-header">
                    <span class="attempt-number">Intento #@attempt.AttemptNumber</span>
                    <span class="badge @(isSuccess ? "badge-success" : "badge-danger")">
                        @(attempt.IsManual
                            ? (isSuccess ? "🔄 Manual OK" : "🔄 Manual")
                            : (isSuccess ? "🤖 Auto OK" : "🤖 Auto"))
                    </span>
                    <span class="attempt-date">@attempt.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm:ss")</span>
                </div>
                <div class="attempt-details">
                    <span>HTTP: <strong>@(attempt.HttpStatusCode ?? 0)</strong></span>
                    <span>Duración: <strong>@attempt.DurationMs ms</strong></span>
                </div>
                @if (!string.IsNullOrEmpty(attempt.ErrorMessage))
                {
                    <div class="attempt-error">❌ @attempt.ErrorMessage</div>
                }
            </div>
        }
    </div>

    <!-- Payload -->
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-top: 1.5rem;">
        <h2 style="margin: 0;">📦 Payload</h2>
        <button class="btn btn-sm btn-secondary" @onclick="CopyPayload">
            @(_copied ? "✅ Copiado!" : "📋 Copiar")
        </button>
    </div>
    <div class="payload-viewer">
        <pre><code>@FormatJson(_log.Payload)</code></pre>
    </div>
}

@code {
    [Parameter] public long LogId { get; set; }

    private DeliveryLog? _log;
    private List<DeliveryAttempt> _attempts = [];
    private bool _isRetrying;
    private bool _copied;
    private string? _message;
    private string _messageClass = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        MonitorNotify.OnDeliveryChanged += OnChanged;
        await LoadData();
    }

    private async Task OnChanged()
    {
        await InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    private async Task LoadData()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();

        _log = await db.DeliveryLogs
            .Include(l => l.Tenant)
            .Include(l => l.Attempts.OrderBy(a => a.AttemptNumber))
            .FirstOrDefaultAsync(l => l.Id == LogId);

        _attempts = _log?.Attempts ?? [];
    }

    private async Task RetryNow()
    {
        _isRetrying = true;
        _message = null;
        var result = await Worker.RetryManualAsync(LogId);
        if (result.IsSuccess)
        {
            _message = $"✅ Reenvío exitoso (HTTP {result.StatusCode})";
            _messageClass = "alert-success";
        }
        else
        {
            _message = $"❌ Falló: {result.ErrorMessage}";
            _messageClass = "alert-danger";
        }
        _isRetrying = false;
        await LoadData();
    }

    private async Task CopyPayload()
    {
        if (_log?.Payload is null) return;
        var json = FormatJson(_log.Payload);
        await JS.InvokeVoidAsync("clipboardHelper.copyText", json);
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
        StateHasChanged();
    }

    private string GetStatusLabel(DeliveryStatus s) => s switch
    {
        DeliveryStatus.Success => "✅ Éxito",
        DeliveryStatus.ManualRetry => "🔄 Manual OK",
        DeliveryStatus.Scheduled => "⏳ Programado",
        _ => "❌ Fallido"
    };

    private static string FormatJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "(vacío)";
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(json);
            return System.Text.Json.JsonSerializer.Serialize(doc, new System.Text.Json.JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch { return json; }
    }

    private static string FormatTimeUntil(DateTime futureUtc)
    {
        var diff = futureUtc - DateTime.UtcNow;
        if (diff.TotalSeconds <= 0) return "ahora";
        if (diff.TotalDays >= 1) return $"{(int)diff.TotalDays}d {diff.Hours}h";
        if (diff.TotalHours >= 1) return $"{(int)diff.TotalHours}h {diff.Minutes}min";
        if (diff.TotalMinutes >= 1) return $"{(int)diff.TotalMinutes}min {diff.Seconds}s";
        return $"{(int)diff.TotalSeconds}s";
    }

    public void Dispose() => MonitorNotify.OnDeliveryChanged -= OnChanged;
}

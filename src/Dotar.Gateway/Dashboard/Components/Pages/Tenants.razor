@page "/tenants"
@page "/tenants/create"
@page "/tenants/{Id:int}/edit"
@using Dotar.Gateway.Domain.Entities
@using Dotar.Gateway.Infrastructure.Data
@using Dotar.Gateway.Infrastructure.Services
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory
@inject TenantCacheService CacheService
@inject NavigationManager Navigation
@implements IDisposable

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
    @(_isEditing ? "Editar Tenant" : _isCreating ? "Nuevo Tenant" : "Tenants")
</MudText>

@if (_isCreating || _isEditing)
{
    <MudPaper Class="pa-6" MaxWidth="600px" Elevation="2">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_form.Name" Label="Nombre"
                          Placeholder="Mi Sistema Origen" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_form.Slug" Label="Slug"
                          HelperText="Usado en la URL: /ingest/{slug}"
                          Placeholder="mi-sistema" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_form.WebhookSecret" Label="Webhook Secret"
                          HelperText="Secret HMAC del sistema origen (Opcional)"
                          InputType="@(_showSecret ? InputType.Text : InputType.Password)" 
                          Adornment="Adornment.End" 
                          AdornmentIcon="@(_showSecret ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="@(() => _showSecret = !_showSecret)"
                          Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_form.TargetUrl" Label="URL de Destino"
                          Placeholder="https://mi-sistema.com/api/webhooks" Variant="Variant.Outlined" />
            <MudSelect T="SignatureScheme" @bind-Value="_form.SignatureScheme"
                       Label="Esquema de firma" Variant="Variant.Outlined"
                       HelperText="Define qué header y formato usa el sistema origen">
                <MudSelectItem T="SignatureScheme" Value="SignatureScheme.WooCommerce">WooCommerce (X-WC-Webhook-Signature, base64)</MudSelectItem>
                <MudSelectItem T="SignatureScheme" Value="SignatureScheme.GitHub">GitHub (X-Hub-Signature-256, sha256=hex)</MudSelectItem>
                <MudSelectItem T="SignatureScheme" Value="SignatureScheme.Generic">Genérico (header configurable, hex)</MudSelectItem>
                <MudSelectItem T="SignatureScheme" Value="SignatureScheme.None">Sin validación (no recomendado)</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_form.SignatureHeader" Label="Header de firma (opcional)"
                          HelperText="Override del header esperado. Si vacío, se usa el default del esquema."
                          Placeholder="X-Webhook-Signature" Variant="Variant.Outlined" />
            <MudSelect T="int" @bind-Value="_form.TenantGroupId" Label="Grupo" Variant="Variant.Outlined">
                <MudSelectItem T="int" Value="0">— Sin grupo —</MudSelectItem>
                @foreach (var g in _groups)
                {
                    <MudSelectItem T="int" Value="@g.Id">@g.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int" @bind-Value="_form.RetryPolicyId" Label="Política de Reintento" Variant="Variant.Outlined">
                <MudSelectItem T="int" Value="0">— Usar política por defecto —</MudSelectItem>
                @foreach (var p in _policies)
                {
                    <MudSelectItem T="int" Value="@p.Id">@p.Name (@(p.Steps.Count) pasos)</MudSelectItem>
                }
            </MudSelect>
            <MudSwitch @bind-Value="_form.IsActive" Color="Color.Success" Label="Activo" />

            <MudStack Row="true" Spacing="2" Class="mt-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save" OnClick="SaveTenant">
                    Guardar
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/tenants">Cancelar</MudButton>
            </MudStack>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-2">@_errorMessage</MudAlert>
            }
        </MudStack>
    </MudPaper>
}
else
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" Href="/tenants/create" Class="mb-4">
        Nuevo Tenant
    </MudButton>

    @if (_tenants.Any())
    {
        <MudSimpleTable Hover="true" Dense="true" Elevation="2">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Grupo</th>
                    <th>Slug</th>
                    <th>URL Destino</th>
                    <th>Política</th>
                    <th>Estado</th>
                    <th>URL Ingesta</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in _tenants)
                {
                    <tr>
                        <td>@t.Name</td>
                        <td><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@(t.TenantGroup?.Name ?? "—")</MudChip></td>
                        <td><code>@t.Slug</code></td>
                        <td style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@t.TargetUrl</td>
                        <td><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@(t.RetryPolicy?.Name ?? "Default")</MudChip></td>
                        <td>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(t.IsActive ? Color.Success : Color.Error)">
                                @(t.IsActive ? "Activo" : "Inactivo")
                            </MudChip>
                        </td>
                        <td><code>/ingest/@t.Slug</code></td>
                        <td>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Href="@($"/tenants/{t.Id}/edit")" />
                            <MudIconButton Icon="@(t.IsActive ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                                           Size="Size.Small"
                                           Color="@(t.IsActive ? Color.Error : Color.Success)"
                                           OnClick="() => ToggleActive(t)" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No hay tenants configurados. ¡Crea el primero!
        </MudAlert>
    }
}

@code {
    [Parameter] public int? Id { get; set; }

    private List<Tenant> _tenants = [];
    private List<RetryPolicy> _policies = [];
    private List<TenantGroup> _groups = [];
    private TenantFormModel _form = new();
    private string? _errorMessage;
    private bool _showSecret = false;

    private bool _isCreating => Navigation.Uri.EndsWith("/create", StringComparison.OrdinalIgnoreCase);
    private bool _isEditing => Navigation.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        await HandleRouteAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(async () =>
        {
            await HandleRouteAsync();
            StateHasChanged();
        });
    }

    private async Task HandleRouteAsync()
    {
        _errorMessage = null;
        if (_isEditing)
        {
            var editId = ExtractIdFromUri();
            if (editId.HasValue)
            {
                Id = editId;
                await LoadTenantForEdit(editId.Value);
            }
        }
        else if (_isCreating)
        {
            _form = new TenantFormModel();
        }
        await LoadTenants();
    }

    private int? ExtractIdFromUri()
    {
        var uri = Navigation.Uri;
        var match = System.Text.RegularExpressions.Regex.Match(uri, @"/tenants/(\d+)/edit",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return match.Success && int.TryParse(match.Groups[1].Value, out var id) ? id : null;
    }

    private async Task LoadTenantForEdit(int tenantId)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        var tenant = await db.Tenants.FindAsync(tenantId);
        if (tenant is not null)
        {
            _form = new TenantFormModel
            {
                Name = tenant.Name,
                Slug = tenant.Slug,
                WebhookSecret = tenant.WebhookSecret,
                TargetUrl = tenant.TargetUrl,
                IsActive = tenant.IsActive,
                SignatureScheme = tenant.SignatureScheme,
                SignatureHeader = tenant.SignatureHeader ?? string.Empty,
                RetryPolicyId = tenant.RetryPolicyId ?? 0,
                TenantGroupId = tenant.TenantGroupId ?? 0
            };
        }
    }

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;

    private async Task LoadTenants()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        _tenants = await db.Tenants
            .Include(t => t.RetryPolicy)
            .Include(t => t.TenantGroup)
            .OrderBy(t => t.Name).ToListAsync();
        _policies = await db.RetryPolicies.Include(p => p.Steps).OrderBy(p => p.Name).ToListAsync();
        _groups = await db.TenantGroups.OrderBy(g => g.Name).ToListAsync();
    }

    private async Task SaveTenant()
    {
        _errorMessage = null;
        if (string.IsNullOrWhiteSpace(_form.Name) ||
            string.IsNullOrWhiteSpace(_form.Slug) ||
            string.IsNullOrWhiteSpace(_form.TargetUrl))
        {
            _errorMessage = "Todos los campos son obligatorios.";
            return;
        }

        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();

        if (_isEditing && Id.HasValue)
        {
            var tenant = await db.Tenants.FindAsync(Id.Value);
            if (tenant is null) return;
            var oldSlug = tenant.Slug;
            tenant.Name = _form.Name;
            tenant.Slug = _form.Slug.ToLowerInvariant().Trim();
            tenant.WebhookSecret = _form.WebhookSecret;
            tenant.TargetUrl = _form.TargetUrl;
            tenant.IsActive = _form.IsActive;
            tenant.SignatureScheme = _form.SignatureScheme;
            tenant.SignatureHeader = string.IsNullOrWhiteSpace(_form.SignatureHeader) ? null : _form.SignatureHeader.Trim();
            tenant.RetryPolicyId = _form.RetryPolicyId == 0 ? null : _form.RetryPolicyId;
            tenant.TenantGroupId = _form.TenantGroupId == 0 ? null : _form.TenantGroupId;
            tenant.UpdatedAt = DateTime.UtcNow;
            CacheService.Invalidate(oldSlug);
            if (oldSlug != tenant.Slug) CacheService.Invalidate(tenant.Slug);
        }
        else
        {
            var slug = _form.Slug.ToLowerInvariant().Trim();
            if (await db.Tenants.AnyAsync(t => t.Slug == slug))
            {
                _errorMessage = $"El slug '{slug}' ya está en uso.";
                return;
            }
            db.Tenants.Add(new Tenant
            {
                Name = _form.Name, Slug = slug, WebhookSecret = _form.WebhookSecret,
                TargetUrl = _form.TargetUrl, IsActive = _form.IsActive,
                SignatureScheme = _form.SignatureScheme,
                SignatureHeader = string.IsNullOrWhiteSpace(_form.SignatureHeader) ? null : _form.SignatureHeader.Trim(),
                RetryPolicyId = _form.RetryPolicyId == 0 ? null : _form.RetryPolicyId,
                TenantGroupId = _form.TenantGroupId == 0 ? null : _form.TenantGroupId,
                CreatedAt = DateTime.UtcNow
            });
        }
        await db.SaveChangesAsync();
        Navigation.NavigateTo("/tenants");
    }

    private async Task ToggleActive(Tenant tenant)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        var entity = await db.Tenants.FindAsync(tenant.Id);
        if (entity is null) return;
        entity.IsActive = !entity.IsActive;
        entity.UpdatedAt = DateTime.UtcNow;
        await db.SaveChangesAsync();
        CacheService.Invalidate(entity.Slug);
        await LoadTenants();
    }

    private class TenantFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string WebhookSecret { get; set; } = string.Empty;
        public string TargetUrl { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
        public SignatureScheme SignatureScheme { get; set; } = SignatureScheme.WooCommerce;
        public string SignatureHeader { get; set; } = string.Empty;
        public int RetryPolicyId { get; set; }
        public int TenantGroupId { get; set; }
    }
}

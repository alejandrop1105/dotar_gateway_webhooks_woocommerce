@page "/tenants"
@page "/tenants/create"
@page "/tenants/{Id:int}/edit"
@using Dotar.Gateway.Application
@using Dotar.Gateway.Domain.Entities
@using Dotar.Gateway.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.DependencyInjection
@inject IServiceScopeFactory ScopeFactory
@inject IProveedorRuteoCatalog ProveedorCatalog
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
    @(_isEditing ? "Editar Tenant" : _isCreating ? "Nuevo Tenant" : "Tenants")
</MudText>

@if (_isCreating || _isEditing)
{
    <MudPaper Class="pa-6" MaxWidth="600px" Elevation="2">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_form.Name" Label="Nombre"
                          Placeholder="Mi Sistema Origen" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_form.Slug" Label="Slug"
                          HelperText="@(_isEditing ? "El slug es inmutable y no puede modificarse" : "Usado en la URL: /ingest/{slug}")"
                          Placeholder="mi-sistema" Variant="Variant.Outlined"
                          Disabled="@_isEditing" />
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="_form.WebhookSecret" Label="Webhook Secret"
                              HelperText="@(_form.SignatureScheme == SignatureScheme.None
                                  ? "No se usa: el tenant está configurado sin validación de firma"
                                  : "Secret HMAC del sistema origen (formato base64 recomendado)")"
                              InputType="@(_showSecret ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showSecret ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => _showSecret = !_showSecret)"
                              Disabled="@(_form.SignatureScheme == SignatureScheme.None)"
                              Variant="Variant.Outlined" Class="flex-grow-1" />
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AutoAwesome"
                           OnClick="GenerateSecret"
                           Disabled="@(_form.SignatureScheme == SignatureScheme.None)">
                    Generar
                </MudButton>
            </MudStack>
            @if (_form.SignatureScheme == SignatureScheme.None)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-1">
                    Sin validación de firma: el endpoint <code>/ingest/{slug}</code> aceptará cualquier
                    request sin verificar HMAC. Usalo solo en entornos confiables o para debug.
                </MudAlert>
            }
            <MudTextField @bind-Value="_form.TargetUrl" Label="URL de Destino"
                          Placeholder="https://mi-sistema.com/api/webhooks" Variant="Variant.Outlined" />
            <MudSelect T="SignatureScheme" @bind-Value="_form.SignatureScheme"
                       Label="Esquema de firma" Variant="Variant.Outlined"
                       HelperText="Define qué header y formato usa el sistema origen">
                <MudSelectItem T="SignatureScheme" Value="SignatureScheme.WooCommerce">WooCommerce (X-WC-Webhook-Signature, base64)</MudSelectItem>
                <MudSelectItem T="SignatureScheme" Value="SignatureScheme.GitHub">GitHub (X-Hub-Signature-256, sha256=hex)</MudSelectItem>
                <MudSelectItem T="SignatureScheme" Value="SignatureScheme.Generic">Genérico (header configurable, hex)</MudSelectItem>
                <MudSelectItem T="SignatureScheme" Value="SignatureScheme.None">Sin validación (no recomendado)</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_form.SignatureHeader" Label="Header de firma (opcional)"
                          HelperText="Override del header esperado. Si vacío, se usa el default del esquema."
                          Placeholder="X-Webhook-Signature" Variant="Variant.Outlined" />
            <MudSelect T="int" @bind-Value="_form.TenantGroupId" Label="Grupo" Variant="Variant.Outlined">
                <MudSelectItem T="int" Value="0">— Sin grupo —</MudSelectItem>
                @foreach (var g in _groups)
                {
                    <MudSelectItem T="int" Value="@g.Id">@g.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int" @bind-Value="_form.RetryPolicyId" Label="Política de Reintento" Variant="Variant.Outlined">
                <MudSelectItem T="int" Value="0">— Usar política por defecto —</MudSelectItem>
                @foreach (var p in _policies)
                {
                    <MudSelectItem T="int" Value="@p.Id">@p.Name (@(p.Steps.Count) pasos)</MudSelectItem>
                }
            </MudSelect>
            <MudSwitch @bind-Value="_form.IsActive" Color="Color.Success" Label="Activo" />

            @* ─── Ruteo por proveedor (multi-sucursal) ─── *@
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.subtitle2" Class="mb-1">Ruteo por proveedor</MudText>
            <MudSwitch @bind-Value="_form.RuteoProveedorActivo" Color="Color.Info"
                       Label="Activar ruteo por proveedor" />
            @if (_form.RuteoProveedorActivo)
            {
                <MudSelect T="string" @bind-Value="_form.ProveedorRuteoNombre"
                           Label="Proveedor de ruteo"
                           HelperText="El proveedor que extrae la sucursal del payload"
                           Variant="Variant.Outlined" Required="true">
                    @foreach (var key in _proveedoresDisponibles)
                    {
                        <MudSelectItem T="string" Value="@key">@key</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="_form.SucursalMetaKey"
                              Label="Meta Key de sucursal"
                              HelperText="Campo meta_data del pedido con el ID de sucursal (ej. _woosea_item_id)"
                              Placeholder="_woosea_item_id" Variant="Variant.Outlined" Required="true" />
                <MudTextField @bind-Value="_form.SucursalMetaSeparador"
                              Label="Separador de sucursal (opcional)"
                              HelperText="Si el valor contiene separador, se toma la parte izquierda (ej. :)"
                              Placeholder=":" Variant="Variant.Outlined" />
            }

            <MudStack Row="true" Spacing="2" Class="mt-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save" OnClick="SaveTenant">
                    Guardar
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/tenants">Cancelar</MudButton>
            </MudStack>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-2">@_errorMessage</MudAlert>
            }
        </MudStack>
    </MudPaper>
}
else
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" Href="/tenants/create" Class="mb-4">
        Nuevo Tenant
    </MudButton>

    @if (_tenants.Any())
    {
        <MudSimpleTable Hover="true" Dense="true" Elevation="2">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Grupo</th>
                    <th>Slug</th>
                    <th>URL Destino</th>
                    <th>Política</th>
                    <th>Estado</th>
                    <th>URL Ingesta</th>
                    <th style="min-width: 140px; white-space: nowrap;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in _tenants)
                {
                    <tr>
                        <td>@t.Name</td>
                        <td><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@(t.TenantGroup?.Name ?? "—")</MudChip></td>
                        <td><code>@t.Slug</code></td>
                        <td style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@t.TargetUrl</td>
                        <td><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@(t.RetryPolicy?.Name ?? "Default")</MudChip></td>
                        <td>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(t.IsActive ? Color.Success : Color.Error)">
                                @(t.IsActive ? "Activo" : "Inactivo")
                            </MudChip>
                        </td>
                        <td><code>/ingest/@t.Slug</code></td>
                        <td style="min-width: 180px; white-space: nowrap;">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Href="@($"/tenants/{t.Id}/edit")" />
                            <MudIconButton Icon="@(t.IsActive ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                                           Size="Size.Small"
                                           Color="@(t.IsActive ? Color.Error : Color.Success)"
                                           OnClick="() => ToggleActive(t)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Webhook"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="Ver configuración de proveedor"
                                           OnClick="@(() => Navigation.NavigateTo($"/proveedores?tenant={t.Slug}"))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="() => DeleteTenant(t)" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No hay tenants configurados. ¡Crea el primero!
        </MudAlert>
    }
}

@code {
    [Parameter] public int? Id { get; set; }

    private List<Tenant> _tenants = [];
    private List<RetryPolicy> _policies = [];
    private List<TenantGroup> _groups = [];
    private IReadOnlyCollection<string> _proveedoresDisponibles = [];
    private TenantFormModel _form = new();
    private string? _errorMessage;
    private bool _showSecret = false;
    /// <summary>Slug del tenant en edición. Inmutable: se usa como identificador en UpdateAsync.</summary>
    private string? _editingSlug;

    private bool _isCreating => Navigation.Uri.EndsWith("/create", StringComparison.OrdinalIgnoreCase);
    private bool _isEditing => Navigation.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        // Poblar el select de proveedores disponibles desde el catálogo inyectado.
        _proveedoresDisponibles = ProveedorCatalog.KeysValidas;
        Navigation.LocationChanged += OnLocationChanged;
        await HandleRouteAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(async () =>
        {
            await HandleRouteAsync();
            StateHasChanged();
        });
    }

    private async Task HandleRouteAsync()
    {
        _errorMessage = null;
        if (_isEditing)
        {
            var editId = ExtractIdFromUri();
            if (editId.HasValue)
            {
                Id = editId;
                await LoadTenantForEdit(editId.Value);
            }
        }
        else if (_isCreating)
        {
            _form = new TenantFormModel();
        }
        await LoadTenants();
    }

    private int? ExtractIdFromUri()
    {
        var uri = Navigation.Uri;
        var match = System.Text.RegularExpressions.Regex.Match(uri, @"/tenants/(\d+)/edit",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return match.Success && int.TryParse(match.Groups[1].Value, out var id) ? id : null;
    }

    private async Task LoadTenantForEdit(int tenantId)
    {
        // Scope corto: el DbContext se libera al salir del método.
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();

        var tenant = await db.Tenants.AsNoTracking().FirstOrDefaultAsync(t => t.Id == tenantId);
        if (tenant is not null)
        {
            // Capturar el slug inmutable antes de poblar el formulario.
            _editingSlug = tenant.Slug;
            _form = new TenantFormModel
            {
                Name                  = tenant.Name,
                Slug                  = tenant.Slug,
                WebhookSecret         = tenant.WebhookSecret,
                TargetUrl             = tenant.TargetUrl,
                IsActive              = tenant.IsActive,
                SignatureScheme       = tenant.SignatureScheme,
                SignatureHeader       = tenant.SignatureHeader ?? string.Empty,
                RetryPolicyId         = tenant.RetryPolicyId ?? 0,
                TenantGroupId         = tenant.TenantGroupId ?? 0,
                RuteoProveedorActivo  = tenant.RuteoProveedorActivo,
                ProveedorRuteoNombre  = tenant.ProveedorRuteoNombre ?? string.Empty,
                SucursalMetaKey       = tenant.SucursalMetaKey ?? string.Empty,
                SucursalMetaSeparador = tenant.SucursalMetaSeparador ?? string.Empty
            };
        }
    }

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;

    private async Task LoadTenants()
    {
        // Scope corto: el DbContext se libera al salir del método.
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();

        _tenants = await db.Tenants
            .AsNoTracking()
            .Include(t => t.RetryPolicy)
            .Include(t => t.TenantGroup)
            .OrderBy(t => t.Name).ToListAsync();
        _policies = await db.RetryPolicies.AsNoTracking().Include(p => p.Steps).OrderBy(p => p.Name).ToListAsync();
        _groups = await db.TenantGroups.AsNoTracking().OrderBy(g => g.Name).ToListAsync();
    }

    private async Task SaveTenant()
    {
        _errorMessage = null;
        if (string.IsNullOrWhiteSpace(_form.Name) ||
            string.IsNullOrWhiteSpace(_form.Slug) ||
            string.IsNullOrWhiteSpace(_form.TargetUrl))
        {
            _errorMessage = "Todos los campos son obligatorios.";
            return;
        }

        if (_isEditing && Id.HasValue)
        {
            // Rama editar: delega en TenantAppService.UpdateAsync.
            // El slug es inmutable — se usa _editingSlug como identificador.
            var slugEdicion = _editingSlug ?? _form.Slug;

            // Si el tenant es sin firma, el secret no aplica → forzar vacío.
            var effectiveSecret = _form.SignatureScheme == SignatureScheme.None
                ? string.Empty
                : _form.WebhookSecret;

            // 0 = desasociar FK, >0 = asignar FK, null = no cambiar (UpdateTenantInput usa int? nullable)
            var updateInput = new UpdateTenantInput(
                Name:                  _form.Name,
                TargetUrl:             _form.TargetUrl,
                WebhookSecret:         effectiveSecret,
                SignatureScheme:       _form.SignatureScheme,
                SignatureHeader:       _form.SignatureHeader,
                IsActive:              _form.IsActive,
                RetryPolicyId:         _form.RetryPolicyId,
                TenantGroupId:         _form.TenantGroupId,
                RuteoProveedorActivo:  _form.RuteoProveedorActivo,
                ProveedorRuteoNombre:  _form.ProveedorRuteoNombre,
                SucursalMetaKey:       _form.SucursalMetaKey,
                SucursalMetaSeparador: _form.SucursalMetaSeparador);

            // Scope corto: el AppService (y su DbContext) se libera al salir del bloque.
            using var scope = ScopeFactory.CreateScope();
            var appService = scope.ServiceProvider.GetRequiredService<TenantAppService>();
            var updateResult = await appService.UpdateAsync(slugEdicion, updateInput);
            if (!updateResult.IsSuccess)
            {
                _errorMessage = updateResult.Message;
                return;
            }

            Navigation.NavigateTo("/tenants");
            return;
        }
        else
        {
            // Validar slug antes de delegar (cierra bug: dashboard ahora rechaza slugs inválidos)
            var slugNormalizado = Tenant.NormalizeSlug(_form.Slug);
            if (!Tenant.IsValidSlug(slugNormalizado))
            {
                _errorMessage = "El 'slug' debe ser lowercase alfanumérico con guiones, 1–100 chars, sin guión inicial o final.";
                return;
            }

            var input = new CreateTenantInput(
                Name:                  _form.Name,
                Slug:                  _form.Slug,
                TargetUrl:             _form.TargetUrl,
                WebhookSecret:         _form.WebhookSecret,
                SignatureScheme:       _form.SignatureScheme,
                SignatureHeader:       _form.SignatureHeader,
                IsActive:              _form.IsActive,
                RetryPolicyId:         _form.RetryPolicyId == 0 ? null : _form.RetryPolicyId,
                TenantGroupId:         _form.TenantGroupId == 0 ? null : _form.TenantGroupId,
                RuteoProveedorActivo:  _form.RuteoProveedorActivo,
                ProveedorRuteoNombre:  _form.ProveedorRuteoNombre,
                SucursalMetaKey:       _form.SucursalMetaKey,
                SucursalMetaSeparador: _form.SucursalMetaSeparador);

            // Scope corto: el AppService (y su DbContext) se libera al salir del bloque.
            using var scope = ScopeFactory.CreateScope();
            var appService = scope.ServiceProvider.GetRequiredService<TenantAppService>();
            var createResult = await appService.CreateAsync(input);
            if (!createResult.IsSuccess)
            {
                _errorMessage = createResult.Message;
                return;
            }
            Navigation.NavigateTo("/tenants");
            return;
        }
    }

    private async Task DeleteTenant(Tenant tenant)
    {
        // Contar entregas históricas para el mensaje del diálogo (UX — scope corto para la query).
        int deliveryCount;
        using (var scope = ScopeFactory.CreateScope())
        {
            var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
            deliveryCount = await db.DeliveryLogs.AsNoTracking().CountAsync(d => d.TenantId == tenant.Id);
        }

        var parameters = new DialogParameters
        {
            ["ContentText"] = $"¿Eliminar el tenant '{tenant.Name}' ({tenant.Slug})? " +
                              (deliveryCount > 0
                                  ? $"Se borrarán también {deliveryCount} registros de entrega históricos. Esta acción es irreversible."
                                  : "Esta acción es irreversible."),
            ["ButtonText"] = "Eliminar",
            ["Color"] = Color.Error
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirmar eliminación", parameters);
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled) return;

        // Delegar en AppService (contiene la lógica de borrado + invalidación de caché).
        using var deleteScope = ScopeFactory.CreateScope();
        var appService = deleteScope.ServiceProvider.GetRequiredService<TenantAppService>();
        var result = await appService.DeleteAsync(tenant.Slug);
        if (result.IsSuccess)
            Snackbar.Add($"Tenant '{tenant.Slug}' eliminado.", Severity.Success);
        else
            Snackbar.Add(result.Message ?? "Error al eliminar el tenant.", Severity.Error);

        await LoadTenants();
    }

    private void GenerateSecret()
    {
        Span<byte> bytes = stackalloc byte[32];
        System.Security.Cryptography.RandomNumberGenerator.Fill(bytes);
        _form.WebhookSecret = Convert.ToBase64String(bytes);
        _showSecret = true;
    }

    private async Task ToggleActive(Tenant tenant)
    {
        // Delegar en AppService (inversión de IsActive + UpdatedAt + invalidación de caché).
        using var scope = ScopeFactory.CreateScope();
        var appService = scope.ServiceProvider.GetRequiredService<TenantAppService>();
        var result = await appService.ToggleActiveAsync(tenant.Slug);
        if (!result.IsSuccess)
            Snackbar.Add(result.Message ?? "Error al cambiar el estado del tenant.", Severity.Error);
        await LoadTenants();
    }

    private class TenantFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string WebhookSecret { get; set; } = string.Empty;
        public string TargetUrl { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
        public SignatureScheme SignatureScheme { get; set; } = SignatureScheme.WooCommerce;
        public string SignatureHeader { get; set; } = string.Empty;
        public int RetryPolicyId { get; set; }
        public int TenantGroupId { get; set; }

        // ─── Ruteo por proveedor ─────────────────────────────────────────────
        public bool RuteoProveedorActivo { get; set; } = false;
        public string ProveedorRuteoNombre { get; set; } = string.Empty;
        public string SucursalMetaKey { get; set; } = string.Empty;
        public string SucursalMetaSeparador { get; set; } = string.Empty;
    }
}

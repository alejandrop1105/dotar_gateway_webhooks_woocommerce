@page "/monitor"
@using Dotar.Gateway.Domain.Entities
@using Dotar.Gateway.Infrastructure.Data
@using Dotar.Gateway.Infrastructure.Services
@using Dotar.Gateway.Workers
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory
@inject RedisQueueService Queue
@inject MonitorNotificationService MonitorNotify
@inject WebhookDispatcherWorker Worker
@implements IDisposable

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" Class="mr-2" /> Monitor de Entregas
</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h3" Color="Color.Primary">@_pendingCount</MudText>
            <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">En Cola Redis</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h3" Color="Color.Success">@_successCount</MudText>
            <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">Exitosos</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h3" Color="Color.Error">@_failedCount</MudText>
            <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">Fallidos</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h3">@_successRate%</MudText>
            <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">Tasa de Éxito</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4" Wrap="Wrap.Wrap">
    <MudSelect T="int" @bind-Value="_filterTenantId" Label="Tenant" Variant="Variant.Outlined"
               Dense="true" Style="max-width:200px;">
        <MudSelectItem T="int" Value="0">Todos los tenants</MudSelectItem>
        @foreach (var t in _tenants)
        {
            <MudSelectItem T="int" Value="@t.Id">@t.Name</MudSelectItem>
        }
    </MudSelect>
    <MudSelect T="string" @bind-Value="_filterStatus" Label="Estado" Variant="Variant.Outlined"
               Dense="true" Style="max-width:160px;">
        <MudSelectItem T="string" Value="@("")">Todos</MudSelectItem>
        <MudSelectItem T="string" Value="@("success")">✅ Exitosos</MudSelectItem>
        <MudSelectItem T="string" Value="@("failed")">❌ Fallidos</MudSelectItem>
        <MudSelectItem T="string" Value="@("manual")">🔄 Reenvíos</MudSelectItem>
    </MudSelect>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadLogs">
        Actualizar
    </MudButton>

    @if (_selectedIds.Count > 0)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteSelected">
            Eliminar @_selectedIds.Count
        </MudButton>
    }

    @if (_failedCount > 0 && _filterTenantId > 0)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.Replay" OnClick="RetryAllFailed"
                   Disabled="_isRetrying">
            @(_isRetrying ? "Reenviando..." : "Reenviar Fallidos")
        </MudButton>
    }

    <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.Autorenew">
        Auto-refresh activo
    </MudChip>
</MudStack>

@if (!string.IsNullOrEmpty(_message))
{
    <MudAlert Severity="@(_messageClass == "alert-success" ? Severity.Success : Severity.Error)"
              Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => _message = null">
        @_message
    </MudAlert>
}

@if (_logs.Any())
{
    <MudSimpleTable Hover="true" Dense="true" Elevation="2">
        <thead>
            <tr>
                <th style="width:32px;">
                    <MudCheckBox T="bool" Value="@(_selectedIds.Count == _logs.Count && _logs.Count > 0)"
                                 ValueChanged="ToggleSelectAll" Dense="true" />
                </th>
                <th>ID</th>
                <th>Tenant</th>
                <th>Status</th>
                <th>HTTP</th>
                <th>Intentos</th>
                <th>Duración</th>
                <th>Error</th>
                <th>Fecha</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in _logs)
            {
                <tr style="@(_selectedIds.Contains(log.Id) ? "background: rgba(108,99,255,0.1);" : "")">
                    <td>
                        <MudCheckBox T="bool" Value="@_selectedIds.Contains(log.Id)"
                                     ValueChanged="_ => ToggleSelect(log.Id)" Dense="true" />
                    </td>
                    <td>#@log.Id</td>
                    <td>@log.Tenant.Name</td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(log.Status)">
                            @GetStatusLabel(log.Status)
                        </MudChip>
                    </td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Color="@GetHttpColor(log.HttpStatusCode)">
                            @(log.HttpStatusCode ?? 0)
                        </MudChip>
                    </td>
                    <td>@log.AttemptNumber</td>
                    <td>@log.DurationMs ms</td>
                    <td style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:var(--mud-palette-error);">
                        @(log.ErrorMessage ?? "—")
                    </td>
                    <td>
                        @log.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm:ss")
                        @if (log.Status == DeliveryStatus.Scheduled && log.NextRetryAt.HasValue)
                        {
                            <br />
                            <MudText Typo="Typo.caption" Color="Color.Warning">
                                ⏳ Reintento: @log.NextRetryAt.Value.ToLocalTime().ToString("HH:mm:ss")
                            </MudText>
                        }
                    </td>
                    <td>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                       Href="@($"/monitor/{log.Id}")" Title="Ver detalle" />
                        @if ((log.Status == DeliveryStatus.Failed || log.Status == DeliveryStatus.Scheduled) &&
                             !string.IsNullOrEmpty(log.Payload))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Replay" Size="Size.Small"
                                           Color="Color.Success" OnClick="() => RetryManual(log.Id)"
                                           Title="Reenviar" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error" OnClick="() => DeleteSingle(log.Id)"
                                       Title="Eliminar" />
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center"
              Spacing="2" Class="pa-4">
        @if (_page > 1)
        {
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PrevPage"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Anterior
            </MudButton>
        }
        <MudText Typo="Typo.body2">Página @_page</MudText>
        @if (_logs.Count == _pageSize)
        {
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="NextPage"
                       EndIcon="@Icons.Material.Filled.ArrowForward">
                Siguiente
            </MudButton>
        }
    </MudStack>
}
else
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No hay logs de entrega con los filtros seleccionados.
    </MudAlert>
}

@code {
    private List<DeliveryLog> _logs = [];
    private List<Tenant> _tenants = [];
    private int _filterTenantId;
    private string _filterStatus = "";
    private int _page = 1;
    private const int _pageSize = 25;
    private long _pendingCount;
    private int _successCount;
    private int _failedCount;
    private int _successRate;
    private bool _isRetrying;
    private string? _message;
    private string _messageClass = "alert-success";
    private HashSet<long> _selectedIds = [];

    protected override async Task OnInitializedAsync()
    {
        MonitorNotify.OnDeliveryChanged += OnDeliveryChanged;
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        _tenants = await db.Tenants.OrderBy(t => t.Name).ToListAsync();
        await LoadLogs();
    }

    private async Task OnDeliveryChanged()
    {
        await InvokeAsync(async () => { await LoadLogs(); StateHasChanged(); });
    }

    private async Task LoadLogs()
    {
        _pendingCount = await Queue.GetPendingCountAsync();
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        var query = db.DeliveryLogs.Include(l => l.Tenant).AsQueryable();
        if (_filterTenantId > 0) query = query.Where(l => l.TenantId == _filterTenantId);
        if (_filterStatus == "success") query = query.Where(l => l.Status == DeliveryStatus.Success);
        else if (_filterStatus == "failed") query = query.Where(l => l.Status == DeliveryStatus.Failed);
        else if (_filterStatus == "manual") query = query.Where(l => l.Status == DeliveryStatus.ManualRetry);

        var baseQuery = _filterTenantId > 0
            ? db.DeliveryLogs.Where(l => l.TenantId == _filterTenantId) : db.DeliveryLogs;
        _successCount = await baseQuery.CountAsync(l => l.Status == DeliveryStatus.Success || l.Status == DeliveryStatus.ManualRetry);
        _failedCount = await baseQuery.CountAsync(l => l.Status == DeliveryStatus.Failed);
        var total = _successCount + _failedCount;
        _successRate = total > 0 ? (int)Math.Round(_successCount * 100.0 / total) : 100;

        _logs = await query.OrderByDescending(l => l.CreatedAt)
            .Skip((_page - 1) * _pageSize).Take(_pageSize).ToListAsync();
    }

    private async Task RetryManual(long logId)
    {
        _message = null;
        var result = await Worker.RetryManualAsync(logId);
        _message = result.IsSuccess
            ? $"✅ Reenvío #{logId} exitoso (HTTP {result.StatusCode})"
            : $"❌ Reenvío #{logId} falló: {result.ErrorMessage}";
        _messageClass = result.IsSuccess ? "alert-success" : "alert-danger";
        await LoadLogs();
    }

    private async Task RetryAllFailed()
    {
        _isRetrying = true; _message = null;
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        var failedLogs = await db.DeliveryLogs
            .Where(l => l.Status == DeliveryStatus.Failed && l.TenantId == _filterTenantId && l.Payload != null)
            .OrderBy(l => l.CreatedAt).Take(50).Select(l => l.Id).ToListAsync();
        int ok = 0, fail = 0;
        foreach (var logId in failedLogs)
        {
            var result = await Worker.RetryManualAsync(logId);
            if (result.IsSuccess) ok++; else fail++;
        }
        _message = $"🔁 Reenvío masivo: {ok} exitosos, {fail} fallidos de {failedLogs.Count} total";
        _messageClass = fail == 0 ? "alert-success" : "alert-danger";
        _isRetrying = false;
        await LoadLogs();
    }

    private async Task PrevPage() { _page--; await LoadLogs(); }
    private async Task NextPage() { _page++; await LoadLogs(); }

    private Color GetHttpColor(int? statusCode) => statusCode switch
    {
        >= 200 and < 300 => Color.Success,
        >= 300 and < 400 => Color.Warning,
        _ => Color.Error
    };

    private Color GetStatusColor(DeliveryStatus status) => status switch
    {
        DeliveryStatus.Success or DeliveryStatus.ManualRetry => Color.Success,
        DeliveryStatus.Scheduled => Color.Warning,
        _ => Color.Error
    };

    private string GetStatusLabel(DeliveryStatus status) => status switch
    {
        DeliveryStatus.Success => "Éxito",
        DeliveryStatus.ManualRetry => "Manual",
        DeliveryStatus.Scheduled => "Programado",
        _ => "Fallido"
    };

    private void ToggleSelect(long id) { if (!_selectedIds.Remove(id)) _selectedIds.Add(id); }

    private void ToggleSelectAll(bool value)
    {
        if (value) _selectedIds = _logs.Select(l => l.Id).ToHashSet();
        else _selectedIds.Clear();
    }

    private async Task DeleteSelected()
    {
        if (_selectedIds.Count == 0) return;
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        await db.DeliveryLogs.Where(l => _selectedIds.Contains(l.Id)).ExecuteDeleteAsync();
        _selectedIds.Clear();
        _message = "Registros eliminados."; _messageClass = "alert-success";
        await LoadLogs();
    }

    private async Task DeleteSingle(long id)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        await db.DeliveryLogs.Where(l => l.Id == id).ExecuteDeleteAsync();
        _selectedIds.Remove(id);
        await LoadLogs();
    }

    public void Dispose() => MonitorNotify.OnDeliveryChanged -= OnDeliveryChanged;
}

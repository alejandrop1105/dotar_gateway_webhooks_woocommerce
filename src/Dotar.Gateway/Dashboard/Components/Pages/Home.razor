@page "/"
@using Dotar.Gateway.Infrastructure.Data
@using Dotar.Gateway.Infrastructure.Services
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory
@inject RedisQueueService Queue

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="mr-2" /> Dashboard
</MudText>

<MudGrid Class="mb-6">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h3" Color="Color.Default">@_totalTenants</MudText>
            <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">
                Tenants Activos
            </MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h3" Color="Color.Primary">@_pendingQueue</MudText>
            <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">
                En Cola
            </MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h3" Color="Color.Success">@_deliveredToday</MudText>
            <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">
                Entregados Hoy
            </MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h3" Color="Color.Error">@_failedToday</MudText>
            <MudText Typo="Typo.caption" Style="text-transform: uppercase; letter-spacing: 0.05em;">
                Fallidos Hoy
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h5" Class="mb-3">
    <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" /> Actividad Reciente
</MudText>

@if (_recentLogs.Any())
{
    <MudSimpleTable Hover="true" Dense="true" Elevation="2">
        <thead>
            <tr>
                <th>Tenant</th>
                <th>Status</th>
                <th>Intentos</th>
                <th>Duración</th>
                <th>Fecha</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in _recentLogs)
            {
                <tr>
                    <td>@log.Tenant.Name</td>
                    <td>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@GetChipColor(log.HttpStatusCode)">
                            @log.HttpStatusCode
                        </MudChip>
                    </td>
                    <td>@log.AttemptNumber</td>
                    <td>@log.DurationMs ms</td>
                    <td>@log.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}
else
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Sin actividad reciente.
    </MudAlert>
}

@code {
    private int _totalTenants;
    private long _pendingQueue;
    private int _deliveredToday;
    private int _failedToday;
    private List<Dotar.Gateway.Domain.Entities.DeliveryLog> _recentLogs = [];

    protected override async Task OnInitializedAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        var today = DateTime.UtcNow.Date;

        _totalTenants = await db.Tenants.CountAsync(t => t.IsActive);
        _pendingQueue = await Queue.GetPendingCountAsync();
        _deliveredToday = await db.DeliveryLogs
            .CountAsync(l => l.CreatedAt >= today && l.HttpStatusCode >= 200 && l.HttpStatusCode < 300);
        _failedToday = await db.DeliveryLogs
            .CountAsync(l => l.CreatedAt >= today && (l.HttpStatusCode >= 400 || l.HttpStatusCode == 0));
        _recentLogs = await db.DeliveryLogs
            .Include(l => l.Tenant)
            .OrderByDescending(l => l.CreatedAt)
            .Take(10)
            .ToListAsync();
    }

    private Color GetChipColor(int? statusCode) => statusCode switch
    {
        >= 200 and < 300 => Color.Success,
        >= 300 and < 400 => Color.Warning,
        >= 400 or 0 => Color.Error,
        _ => Color.Default
    };
}

@page "/politicas"
@page "/politicas/create"
@page "/politicas/{Id:int}/edit"
@using Dotar.Gateway.Domain.Entities
@using Dotar.Gateway.Infrastructure.Data
@using Dotar.Gateway.Workers
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Navigation
@inject WebhookDispatcherWorker Worker
@implements IDisposable

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Replay" Class="mr-2" />
    @(_isEditing ? "Editar Política" : _isCreating ? "Nueva Política" : "Políticas de Reintento")
</MudText>

@if (_isCreating || _isEditing)
{
    <MudPaper Class="pa-6" MaxWidth="700px" Elevation="2">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_form.Name" Label="Nombre de la Política"
                          Placeholder="Agresiva, Conservadora, etc." Variant="Variant.Outlined" />

            <MudText Typo="Typo.h6" Class="mt-4">⏱️ Pasos de Reintento</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Cada paso define cuánto esperar antes del siguiente intento.
            </MudText>

            @for (int i = 0; i < _form.Steps.Count; i++)
            {
                var idx = i;
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@(idx + 1)</MudChip>
                    <MudText Typo="Typo.body2">→ esperar</MudText>
                    <MudNumericField @bind-Value="_form.Steps[idx].DelayValue" Min="1" Max="999"
                                     Variant="Variant.Outlined" Style="max-width:100px;" Dense="true" />
                    <MudSelect T="DelayUnit" @bind-Value="_form.Steps[idx].DelayUnit"
                               Variant="Variant.Outlined" Dense="true" Style="max-width:140px;">
                        <MudSelectItem T="DelayUnit" Value="DelayUnit.Seconds">segundos</MudSelectItem>
                        <MudSelectItem T="DelayUnit" Value="DelayUnit.Minutes">minutos</MudSelectItem>
                        <MudSelectItem T="DelayUnit" Value="DelayUnit.Hours">horas</MudSelectItem>
                        <MudSelectItem T="DelayUnit" Value="DelayUnit.Days">días</MudSelectItem>
                    </MudSelect>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   Color="Color.Error" OnClick="() => RemoveStep(idx)" />
                </MudStack>
            }

            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="AddStep">
                Agregar Paso
            </MudButton>

            @if (_form.Steps.Any())
            {
                <MudPaper Class="pa-4 mt-4" Elevation="0" Style="background: rgba(108,99,255,0.05); border: 1px solid rgba(108,99,255,0.2); border-radius: 8px;">
                    <MudText Typo="Typo.h6" Class="mb-3">📊 Vista previa — Timeline acumulada</MudText>
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        <MudTimelineItem Color="Color.Success" Size="Size.Small">
                            <MudText Typo="Typo.body2"><strong>Intento 1</strong> — Inmediato</MudText>
                        </MudTimelineItem>
                        @foreach (var item in GetTimelineItems())
                        {
                            <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                                <MudText Typo="Typo.body2">
                                    <strong>Intento @item.Number</strong> — a los @FormatTimeSpan(item.Accumulated)
                                    <MudText Typo="Typo.caption">(espera @item.StepLabel)</MudText>
                                </MudText>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        Tiempo total: <strong>@FormatTimeSpan(GetTotalTime())</strong>
                    </MudText>
                </MudPaper>
            }

            <MudText Typo="Typo.h6" Class="mt-4">🔌 Circuit Breaker</MudText>
            <MudNumericField @bind-Value="_form.CbThreshold" Label="Umbral Mínimo"
                             HelperText="Requests antes de evaluar ratio de fallas"
                             Min="1" Max="50" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="_form.CbDurationSec" Label="Duración Abierto (segundos)"
                             Min="5" Max="300" Variant="Variant.Outlined" />

            <MudStack Row="true" Spacing="2" Class="mt-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save" OnClick="SavePolicy">
                    Guardar
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/politicas">Cancelar</MudButton>
            </MudStack>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
            }
        </MudStack>
    </MudPaper>
}
else
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" Href="/politicas/create" Class="mb-4">
        Nueva Política
    </MudButton>

    @if (_policies.Any())
    {
        <MudSimpleTable Hover="true" Dense="true" Elevation="2">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Pasos</th>
                    <th>Timeline</th>
                    <th>Tenants</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _policies)
                {
                    var steps = p.Steps.OrderBy(s => s.StepNumber).ToList();
                    <tr>
                        <td>
                            @p.Name
                            @if (p.IsDefault)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ml-2">Default</MudChip>
                            }
                        </td>
                        <td><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@steps.Count pasos</MudChip></td>
                        <td style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            @string.Join(" → ", steps.Select(s => s.DisplayText))
                        </td>
                        <td><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@p.Tenants.Count</MudChip></td>
                        <td>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Href="@($"/politicas/{p.Id}/edit")" />
                            @if (!p.IsDefault)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="() => DeletePolicy(p)" />
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    [Parameter] public int? Id { get; set; }
    private List<RetryPolicy> _policies = [];
    private PolicyFormModel _form = new();
    private string? _error;
    private bool _isCreating => Navigation.Uri.EndsWith("/create", StringComparison.OrdinalIgnoreCase);
    private bool _isEditing => Navigation.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        await HandleRouteAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(async () => { await HandleRouteAsync(); StateHasChanged(); });

    private async Task HandleRouteAsync()
    {
        _error = null;
        if (_isEditing)
        {
            var match = System.Text.RegularExpressions.Regex.Match(
                Navigation.Uri, @"/politicas/(\d+)/edit", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            if (match.Success && int.TryParse(match.Groups[1].Value, out var id))
            { Id = id; await LoadPolicyForEdit(id); }
        }
        else if (_isCreating)
        {
            _form = new PolicyFormModel();
            _form.Steps.Add(new StepModel { DelayValue = 5, DelayUnit = DelayUnit.Seconds });
            _form.Steps.Add(new StepModel { DelayValue = 30, DelayUnit = DelayUnit.Seconds });
            _form.Steps.Add(new StepModel { DelayValue = 2, DelayUnit = DelayUnit.Minutes });
        }
        await LoadPolicies();
    }

    private async Task LoadPolicyForEdit(int policyId)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        var p = await db.RetryPolicies.Include(x => x.Steps).FirstOrDefaultAsync(x => x.Id == policyId);
        if (p is not null)
        {
            _form = new PolicyFormModel
            {
                Name = p.Name, CbThreshold = p.CircuitBreakerThreshold,
                CbDurationSec = p.CircuitBreakerDurationSeconds,
                Steps = p.Steps.OrderBy(s => s.StepNumber)
                    .Select(s => new StepModel { DelayValue = s.DelayValue, DelayUnit = s.DelayUnit }).ToList()
            };
        }
    }

    private async Task LoadPolicies()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        _policies = await db.RetryPolicies.Include(p => p.Steps).Include(p => p.Tenants)
            .OrderBy(p => p.Name).ToListAsync();
    }

    private void AddStep() => _form.Steps.Add(new StepModel { DelayValue = 5, DelayUnit = DelayUnit.Seconds });
    private void RemoveStep(int idx) { if (_form.Steps.Count > 0) _form.Steps.RemoveAt(idx); }

    private async Task SavePolicy()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_form.Name)) { _error = "El nombre es obligatorio."; return; }
        if (_form.Steps.Count == 0) { _error = "Debe tener al menos un paso de reintento."; return; }

        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();

        if (_isEditing && Id.HasValue)
        {
            var p = await db.RetryPolicies.Include(x => x.Steps).FirstOrDefaultAsync(x => x.Id == Id.Value);
            if (p is null) return;
            p.Name = _form.Name;
            p.CircuitBreakerThreshold = _form.CbThreshold;
            p.CircuitBreakerDurationSeconds = _form.CbDurationSec;
            db.RetrySteps.RemoveRange(p.Steps);
            for (int i = 0; i < _form.Steps.Count; i++)
            {
                p.Steps.Add(new RetryStep
                {
                    StepNumber = i + 1, DelayValue = _form.Steps[i].DelayValue,
                    DelayUnit = _form.Steps[i].DelayUnit
                });
            }
            Worker.InvalidatePipelineCache(p.Id);
        }
        else
        {
            var policy = new RetryPolicy
            {
                Name = _form.Name, CircuitBreakerThreshold = _form.CbThreshold,
                CircuitBreakerDurationSeconds = _form.CbDurationSec
            };
            for (int i = 0; i < _form.Steps.Count; i++)
            {
                policy.Steps.Add(new RetryStep
                {
                    StepNumber = i + 1, DelayValue = _form.Steps[i].DelayValue,
                    DelayUnit = _form.Steps[i].DelayUnit
                });
            }
            db.RetryPolicies.Add(policy);
        }
        await db.SaveChangesAsync();
        Navigation.NavigateTo("/politicas");
    }

    private async Task DeletePolicy(RetryPolicy policy)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<GatewayDbContext>();
        var p = await db.RetryPolicies.FindAsync(policy.Id);
        if (p is not null) { db.RetryPolicies.Remove(p); await db.SaveChangesAsync(); }
        Worker.InvalidatePipelineCache(policy.Id);
        await LoadPolicies();
    }

    private static TimeSpan GetDelay(StepModel s) => s.DelayUnit switch
    {
        DelayUnit.Seconds => TimeSpan.FromSeconds(s.DelayValue),
        DelayUnit.Minutes => TimeSpan.FromMinutes(s.DelayValue),
        DelayUnit.Hours => TimeSpan.FromHours(s.DelayValue),
        DelayUnit.Days => TimeSpan.FromDays(s.DelayValue),
        _ => TimeSpan.FromSeconds(s.DelayValue)
    };

    private static string FormatStepDelay(StepModel s) => s.DelayUnit switch
    {
        DelayUnit.Seconds => $"{s.DelayValue}s", DelayUnit.Minutes => $"{s.DelayValue}min",
        DelayUnit.Hours => $"{s.DelayValue}h", DelayUnit.Days => $"{s.DelayValue}d",
        _ => $"{s.DelayValue}s"
    };

    private static string FormatTimeSpan(TimeSpan ts) => ts.TotalDays >= 1
        ? $"{(int)ts.TotalDays}d {ts.Hours}h {ts.Minutes}min"
        : ts.TotalHours >= 1 ? $"{(int)ts.TotalHours}h {ts.Minutes}min {ts.Seconds}s"
        : ts.TotalMinutes >= 1 ? $"{(int)ts.TotalMinutes}min {ts.Seconds}s"
        : $"{(int)ts.TotalSeconds}s";

    private TimeSpan GetTotalTime()
    {
        var total = TimeSpan.Zero;
        foreach (var step in _form.Steps)
            total += GetDelay(step);
        return total;
    }

    private List<TimelineItem> GetTimelineItems()
    {
        var items = new List<TimelineItem>();
        var accumulated = TimeSpan.Zero;
        for (int i = 0; i < _form.Steps.Count; i++)
        {
            var step = _form.Steps[i];
            accumulated += GetDelay(step);
            items.Add(new TimelineItem(i + 2, accumulated, FormatStepDelay(step)));
        }
        return items;
    }

    private record TimelineItem(int Number, TimeSpan Accumulated, string StepLabel);

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;

    private class PolicyFormModel
    {
        public string Name { get; set; } = string.Empty;
        public int CbThreshold { get; set; } = 5;
        public int CbDurationSec { get; set; } = 30;
        public List<StepModel> Steps { get; set; } = [];
    }

    private class StepModel
    {
        public int DelayValue { get; set; } = 5;
        public DelayUnit DelayUnit { get; set; } = DelayUnit.Seconds;
    }
}

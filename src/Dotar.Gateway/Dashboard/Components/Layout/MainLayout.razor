@inherits LayoutComponentBase
@using Dotar.Gateway.Infrastructure.Services
@inject TunnelStatusService TunnelStatus
@inject IJSRuntime JS
@implements IDisposable

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* ─── AppBar superior con estado del túnel ─── *@
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2"
                 Style="background: linear-gradient(135deg, #6c63ff, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            ⚡ Dotar Gateway
        </MudText>
        <MudSpacer />

        @if (TunnelStatus.IsConnected)
        {
            <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.Cloud">
                Túnel activo
            </MudChip>
            <MudText Typo="Typo.body2" Class="mx-2">
                <span style="color: var(--mud-palette-success);">@TunnelStatus.TunnelUrl</span><span>/ingest/{slug}</span>
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                           Size="Size.Small"
                           Color="Color.Inherit"
                           OnClick="CopyTunnelUrl"
                           Title="Copiar URL" />
        }
        else
        {
            <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.CloudOff">
                @TunnelStatus.Status
            </MudChip>
            <MudButton Href="/configuracion" Color="Color.Primary" Size="Size.Small" Class="ml-2">
                Configurar →
            </MudButton>
        }
    </MudAppBar>

    @* ─── Drawer (sidebar colapsable) ─── *@
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    @* ─── Contenido principal ─── *@
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task CopyTunnelUrl()
    {
        var url = $"{TunnelStatus.TunnelUrl}/ingest/{{slug}}";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
    }

    protected override void OnInitialized()
    {
        TunnelStatus.OnStatusChanged += OnTunnelStatusChanged;
    }

    private void OnTunnelStatusChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        TunnelStatus.OnStatusChanged -= OnTunnelStatusChanged;
    }

    private MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#6c63ff",
            Secondary = "#a78bfa",
            Success = "#10b981",
            Warning = "#f59e0b",
            Error = "#ef4444",
            Background = "#0f0f1a",
            Surface = "#16213e",
            DrawerBackground = "#1a1a2e",
            AppbarBackground = "#1a1a2e",
            TextPrimary = "#e8e8f0",
            TextSecondary = "#9ca3af",
            ActionDefault = "#9ca3af",
            DrawerText = "#9ca3af",
            DrawerIcon = "#9ca3af",
            LinesDefault = "rgba(255,255,255,0.08)",
            TableLines = "rgba(255,255,255,0.08)",
            Divider = "rgba(255,255,255,0.08)",
        }
    };
}
